fun factorial(n: Int): Int {
    var result: Int = 1
    var i: Int = 1
    while (i <= n) {
        result = result * i
        i = i + 1
    }
    return result
}

fun main(): Unit {
    var x: Int = readInt()
    var factStr: String = ""
    intToString(factorial(x), factStr, 1024)
    var msg: String = ""
    stringConcat("factorial: ", factStr, msg, 1024)
    println(msg)
}