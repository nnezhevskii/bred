fun swapIfGreater(arr: Int[], i: Int, j: Int): Unit {
    if (arr[i] > arr[j]) {
        var tmp: Int = arr[i]
        arr[i] = arr[j]
        arr[j] = tmp
    }
}

fun bubblePass(arr: Int[], size: Int): Unit {
    if (size <= 1) {
        return
    }
    for (i in 0 to size - 1) {
        var next: Int = i + 1
        swapIfGreater(arr, i, next)
    }
}

fun main(): Unit {
    val arr: Int[5]
    arr[0] = 3
    arr[1] = 1
    arr[2] = 4
    arr[3] = 2
    arr[4] = 0
    bubblePass(arr, 4)
    var head: String = ""
    intToString(arr[0], head, 1024)
    var tail: String = ""
    intToString(arr[4], tail, 1024)
    var part: String = ""
    stringConcat(head, ",", part, 1024)
    var line: String = ""
    stringConcat(part, tail, line, 1024)
    println(line)
}
