fun sortThree(a: Int, b: Int, c: Int): Unit {
    var x: Int = a
    var y: Int = b
    var z: Int = c
    var temp: Int = 0

    // Имитируем проход сортировки
    if (x > y) {
        temp = x
        x = y
        y = temp
    }
    if (y > z) {
        temp = y
        y = z
        z = temp
    }
    if (x > y) {
        temp = x
        x = y
        y = temp
    }

    var sx: String = ""
    intToString(x, sx, 1024)
    var sy: String = ""
    intToString(y, sy, 1024)
    var sz: String = ""
    intToString(z, sz, 1024)
    var part1: String = ""
    stringConcat(sx, " ", part1, 1024)
    var part2: String = ""
    stringConcat(part1, sy, part2, 1024)
    var part3: String = ""
    stringConcat(part2, " ", part3, 1024)
    var line: String = ""
    stringConcat(part3, sz, line, 1024)
    println(line)
}

fun main(): Unit {
    sortThree(3, 1, 2)
}