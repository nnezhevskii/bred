fun findMaxIndex(arr: Int[], size: Int): Int {
    if (size <= 0) {
        return -1
    }
    var maxVal: Int = arr[0]
    var maxIdx: Int = 0
    for (i in 1 to size) {
        if (arr[i] > maxVal) {
            maxVal = arr[i]
            maxIdx = i
        }
    }
    return maxIdx
}

fun findMinIndex(arr: Int[], size: Int): Int {
    if (size <= 0) {
        return -1
    }
    var minVal: Int = arr[0]
    var minIdx: Int = 0
    for (i in 1 to size) {
        if (arr[i] < minVal) {
            minVal = arr[i]
            minIdx = i
        }
    }
    return minIdx
}

fun computeSum(arr: Int[], size: Int): Int {
    if (size <= 0) {
        return 0
    }
    var sum: Int = 0
    for (i in 0 to size) {
        sum = sum + arr[i]
    }
    return sum
}

fun main() {
    val arr: Int[50]
    val size: Int = readInt()

    if (size < 0) {
        println("negative size not allowed")
    }
    if (size > 50) {
        println("technical restrictions: size too large")
    }

    for (i in 0 to size) {
        arr[i] = i * 3 + 7
    }

    val maxIdx: Int = findMaxIndex(arr, size)
    val minIdx: Int = findMinIndex(arr, size)
    val total: Int = computeSum(arr, size)

    if (maxIdx == -1) {
        println("array is empty")
    } else {
        val maxVal: Int = arr[maxIdx]
        val minVal: Int = arr[minIdx]
        val rangeVal: Int = maxVal - minVal

        println("max at index " + intToString(maxIdx) + " value " + intToString(maxVal))
        println("min at index " + intToString(minIdx) + " value " + intToString(minVal))
        println("sum is " + intToString(total))
        println("range is " + intToString(rangeVal))

        if (rangeVal == 0) {
            println("all elements are equal")
        }
        if (size == 1) {
            println("single element case")
        }
    }
}