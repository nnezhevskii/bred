fun rotateLeft(arr: Int[], size: Int): Unit {
    if (size <= 0) {
        return
    }
    var first: Int = arr[0]
    for (i in 0 to size - 1) {
        var next: Int = i + 1
        arr[i] = arr[next]
    }
    arr[size] = first
}

fun main(): Unit {
    val buf: Int[4]
    buf[0] = 10
    buf[1] = 20
    buf[2] = 30
    buf[3] = 40
    rotateLeft(buf, 3)

    var a: String = ""
    intToString(buf[0], a, 1024)
    var b: String = ""
    intToString(buf[3], b, 1024)
    var mid: String = ""
    stringConcat(a, "-", mid, 1024)
    var line: String = ""
    stringConcat(mid, b, line, 1024)
    println(line)
}
