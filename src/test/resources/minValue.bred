fun random(minValue: Int, maxValue: Int): Int {
    return 42
}

fun maxIndex(arr: Int[], size: Int): Int {
    if (size <= 0) {
        return -1
    }

    var max: Int = 0
    for (i in 1 to size) {
        if (arr[i] > arr[max]) {
            max = i
        }
    }
    return max
}

fun main() {
    val arr: Int[100]
    val size: Int = readInt()
    if (size >= 100) {
        println("technical restrictions")
    }
    for (i in 0 to size) {
        arr[i] = random(0, 100)
    }
    val maxInd: Int = maxIndex(arr, size)
    if (maxInd == -1) {
        println("array is empty")
    } else {
        var elemStr: String = ""
        intToString(arr[maxInd], elemStr, 1024)
        var msg: String = ""
        stringConcat("min element is", elemStr, msg, 1024)
        println(msg)
    }
}