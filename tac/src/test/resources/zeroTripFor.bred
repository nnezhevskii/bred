fun sumRange(arr: Int[], start: Int, end: Int): Int {
    var total: Int = 0
    for (i in start to end) {
        total = total + arr[i]
    }
    return total
}

fun main(): Unit {
    val arr: Int[4]
    arr[0] = 10
    arr[1] = 20
    arr[2] = 30
    arr[3] = 40

    // Edge: loop never executes when lower bound exceeds upper bound.
    var zeroTrip: Int = sumRange(arr, 5, 1)

    // Edge: single-iteration loop.
    var single: Int = sumRange(arr, 2, 2)

    var zStr: String = ""
    intToString(zeroTrip, zStr, 1024)
    var sStr: String = ""
    intToString(single, sStr, 1024)
    var part: String = ""
    stringConcat(zStr, ":", part, 1024)
    var line: String = ""
    stringConcat(part, sStr, line, 1024)
    println(line)
}
