typeclass Printable<A> {
    fun toPrettyPrinter(a: A): String
}

instance Printable<Int> {
    fun toPrettyPrinter(value: Int): String {
        return intToString(value)
    }
}

instance Printable<String> {
    fun toPrettyPrinter(value: String): String {
        return value + "whoo"
    }
}


fun prettyPrint<A: Printable>(a: A) {
    val str = toPrettyPrinter(a)
    println(str)
}


fun main(): Unit {
    val a: Int = 0
    prettyPrint(a) // << ok
    prettyPrint("Hello World")
}
