fun random(): Int {
    return 42
}

fun maxIndex(arr: Int[], size: Int): Int {
    if (size <= 0) {
        return -1
    }
    var max: Int = 0
    for (i in 1 to size) {
        if (arr[i] > arr[max]) {
            max = i
        }
    }
    return max
}

fun main() {
    val arr: Int[100]
    val maxInd: Int = maxIndex(arr, 100)
}