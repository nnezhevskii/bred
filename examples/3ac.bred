

fun arrayToString(arr: Array<Int>, size: Int): String {
    var buff: String = ""

    if (size == 0) {
        return ""
    }
    if (size == 1) {
        return intToString(arr[0])
    }

    for (i in 0 to size - 1) {
        buff = buff + intToString(arr[i]) + " "
    }
    buff = buff + intToString(arr[size - 1])

    return buff
}


