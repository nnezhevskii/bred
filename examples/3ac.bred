fun main(): Unit {
    val arrSize: Int = readInt()
    val arr: Array<Int>[1024]

    for (i in 0 to arrSize) {
         arr[i] = random(0, 50)
    }

    println(arrayToString(arr, arrSize))

    bubbleSort(arr, arrSize)
    println("After sorting:")
    println(arrayToString(arr, arrSize))

    readInt()
}